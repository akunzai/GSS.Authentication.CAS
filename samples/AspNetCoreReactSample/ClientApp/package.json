{
  "name": "aspnetcorereactsample",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "prestart": "node aspnetcore-https && node aspnetcore-react",
    "start": "vite",
    "build": "tsc && vite build",
    "lint": "eslint ./src/"
  },
  "dependencies": {
    "axios": "1.13.5",
    "bootstrap": "5.3.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-bootstrap": "0.26.3",
    "rimraf": "6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.56.0",
    "web-vitals": "5.1.0",
    "wouter": "3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "10.0.0",
    "vite": "7.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch": "^10.2.2",
      "react-router": "^6.30.3",
      "@remix-run/router": "^1.23.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    }
  }
}
