{
  "name": "aspnetcorereactsample",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prestart": "node aspnetcore-https && node aspnetcore-react",
    "start": "vite",
    "build": "tsc && vite build",
    "lint": "eslint ./src/"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-bootstrap": "0.26.3",
    "rimraf": "6.1.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.0",
    "web-vitals": "5.2.0",
    "wouter": "3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.1",
    "vite": "8.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react-router": "^6.30.3",
      "@remix-run/router": "^1.23.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    }
  }
}